<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <p class="auth-eyebrow">Set a new password</p>
      <h1 class="auth-title">Change your password</h1>
      <p class="auth-subtitle">
        Choose a new password for your account and confirm it below.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="auth-field">
        <%= f.label :password, "New password" %>
        <% if @minimum_password_length %>
          <p class="auth-hint"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirm new password" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="auth-actions">
        <%= f.submit "Change my password", class: "auth-submit" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
